# ==========================================================================
# METFRAA EHS — Environment Variables
# Copy this file to ".env" and fill in real values. NEVER commit .env to git.
# ==========================================================================

# --- Application ---
PORT=3000
NODE_ENV=production
# A long random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-long-random-hex-string

# Public URL of the deployed app (for OAuth redirects). No trailing slash.
APP_BASE_URL=https://ehs.metfraa.com

# --- Google Sign-In (Google Cloud Console > APIs & Services > Credentials) ---
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# --- Microsoft Azure / OneDrive (Azure Portal > App Registrations) ---
AZURE_TENANT_ID=common-or-your-tenant-id
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=your-azure-client-secret-value
# The Microsoft account whose OneDrive will store all files. Use either:
#   - userPrincipalName  (e.g., admin@metfraa.com)
#   - the user's object-id GUID
ONEDRIVE_USER_ID=admin@metfraa.com
# Root folder name inside OneDrive. The app creates/uses this folder.
ONEDRIVE_ROOT_FOLDER=Metfraa-EHS

# --- Admin emails (comma-separated). These can access /admin ---
ADMIN_EMAILS=varadharaj@gmail.com,nirmal@gmail.com
