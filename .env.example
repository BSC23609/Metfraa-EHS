# ==========================================================================
# METFRAA EHS — Environment Variables (TEMPLATE)
#
# This file is just a template showing what variables to set.
# REAL values live in Render's Environment dashboard, NOT in this file.
# Never commit real secrets to git.
# ==========================================================================

# --- Application ---
NODE_ENV=production
PORT=10000
SESSION_SECRET=generate_with_node_-e_console.log(require('crypto').randomBytes(48).toString('hex'))
APP_BASE_URL=https://ehs.metfraa.com

# --- Google Sign-In (from Google Cloud Console) ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Microsoft Azure / OneDrive (from Azure App Registration) ---
AZURE_TENANT_ID=your-tenant-id-guid
AZURE_CLIENT_ID=your-azure-client-id-guid
AZURE_CLIENT_SECRET=your-azure-client-secret

# --- Storage destination ---
# Single Microsoft 365 user whose OneDrive stores ALL submissions.
# MUST be a real M365 user with a license that includes OneDrive.
ONEDRIVE_USER_ID=info@metfraa.com
ONEDRIVE_ROOT_FOLDER=Metfraa-EHS

# --- Admin emails (comma-separated, no spaces) ---
ADMIN_EMAILS=info@metfraa.com,varadharaj@metfraa.com,nirmal@metfraa.com,arasu@metfraa.com